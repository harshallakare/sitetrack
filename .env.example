# Copy this file to packages/database/.env and apps/api/.env as needed.
# See plan doc for the cross-engine story (SQLite by default, Postgres/MySQL optional).

# --- packages/database/.env ---
# One of: sqlite | postgresql | mysql
DATABASE_PROVIDER=sqlite
# sqlite:    file:./dev.db
# postgres:  postgresql://user:password@localhost:5432/sitetrack
# mysql:     mysql://user:password@localhost:3306/sitetrack
DATABASE_URL="file:./dev.db"

# --- apps/api/.env ---
API_PORT=4000
JWT_ACCESS_SECRET=change-me-in-production-access
JWT_REFRESH_SECRET=change-me-in-production-refresh
JWT_ACCESS_TTL=15m
JWT_REFRESH_TTL=30d
# Platform-admin auth is a fully separate credential domain from tenant auth
# (separate login page, separate cookies) -- this MUST be a different secret
# than JWT_ACCESS_SECRET, or a leaked tenant secret could forge admin tokens.
JWT_ADMIN_SECRET=change-me-in-production-admin-do-not-reuse-other-secrets
JWT_ADMIN_ACCESS_TTL=15m
JWT_ADMIN_REFRESH_TTL=7d
# 64 hex chars (32 bytes). Encrypts payment-gateway secrets and notification
# credentials at rest. Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
ENCRYPTION_KEY=change-me-64-hex-characters-0000000000000000000000000000000000000000
UPLOADS_DIR=./uploads
# Pre-restore safety snapshots from the admin panel's Database backup/restore
# page. Requires pg_dump/pg_restore (or mysqldump/mysql) on PATH locally if
# you're on postgres/mysql; sqlite needs no extra tooling.
BACKUPS_DIR=./backups
CORS_ORIGIN=http://localhost:3000

# --- apps/web/.env.local ---
API_URL=http://localhost:4000
