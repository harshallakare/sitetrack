# Copy this to .env.production on the SERVER and fill in real values.
# NEVER commit .env.production -- it's already covered by .gitignore's `.env` rule.
#
# Generate strong secrets with:
#   node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
# Run it 4 times for JWT_ACCESS_SECRET, JWT_REFRESH_SECRET, JWT_ADMIN_SECRET,
# and ENCRYPTION_KEY (ENCRYPTION_KEY must be exactly 64 hex chars).
# scripts/deploy.sh will refuse to start if any of these are still "change-me".

# --- Domain & reverse proxy ---
# `web` and `api` are only published on 127.0.0.1 (see docker-compose.prod.yml)
# -- something needs to sit in front of them for the outside world to reach
# this app. Point your own existing nginx/Caddy/etc. at 127.0.0.1:3000 (web)
# and 127.0.0.1:4000 (api, /webhooks/* only) -- see "Running alongside an
# existing site" in DEPLOY.md. Leave DOMAIN=localhost in that case; your
# existing proxy handles the real domain and TLS.
#
# No existing reverse proxy on this server? Use the bundled Caddy instead:
# `docker compose -f docker-compose.prod.yml --profile caddy --env-file
# .env.production up -d`, with DOMAIN set to your real domain below for
# automatic HTTPS (DNS must already point here first).
DOMAIN=localhost
# Only used if you opt into the bundled `caddy` profile above and 80/443 are
# already taken by something else on this server:
# CADDY_HTTP_BIND=127.0.0.1:8080
# CADDY_HTTPS_BIND=127.0.0.1:8443
# `web`/`api` bind to 127.0.0.1:3000/4000 by default -- override the port
# number if something else on this server is already using those:
# WEB_HOST_BIND_PORT=3001
# API_HOST_BIND_PORT=4001

# --- Database (packages/database) ---
# One of: sqlite | postgresql | mysql -- baked into the api image at build
# time (see docker-compose.prod.yml build.args), so changing this requires
# `docker compose -f docker-compose.prod.yml build api` again, not just a
# restart. SQLite (the default) needs nothing else configured -- the file
# lives in the `sqlite_data` volume and survives container recreation. Fine
# for a single small deployment; switch to Postgres/MySQL if more than one
# person will be using this at the same time (see DEPLOY.md).
DATABASE_PROVIDER=sqlite
DATABASE_URL=file:/repo/packages/database/prisma/data/prod.db

# --- API (apps/api) ---
API_PORT=4000
JWT_ACCESS_SECRET=change-me-generate-a-real-32-byte-secret
JWT_REFRESH_SECRET=change-me-generate-a-different-32-byte-secret
JWT_ACCESS_TTL=15m
JWT_REFRESH_TTL=30d
# Fully separate credential domain from tenant auth -- must never share a
# secret with JWT_ACCESS_SECRET/JWT_REFRESH_SECRET.
JWT_ADMIN_SECRET=change-me-generate-yet-another-32-byte-secret
JWT_ADMIN_ACCESS_TTL=15m
JWT_ADMIN_REFRESH_TTL=7d
# 64 hex chars (32 bytes). Encrypts payment-gateway secrets and notification
# credentials at rest.
ENCRYPTION_KEY=change-me-64-hex-characters-0000000000000000000000000000000000000000
# Absolute path inside the container -- matches the api_uploads volume mount
# in docker-compose.prod.yml. Don't change one without the other.
UPLOADS_DIR=/repo/apps/api/uploads
# Same idea, for the admin panel's pre-restore safety snapshots (matches the
# api_backups volume mount). The on-demand "Download Backup" file itself
# streams straight to the browser and never touches this directory.
BACKUPS_DIR=/repo/apps/api/backups
# The browser never calls the API directly (Next.js proxies server-side), so
# this only matters for direct API testing (curl, Postman) against the
# container -- set to your real domain if you ever publish api's port.
CORS_ORIGIN=https://change-me-your-domain.example.com

# --- Web (apps/web) ---
# api and web run in the same container (see Dockerfile), so this is just
# the container's own loopback -- not reachable from outside. Do not point
# this at a public URL.
API_URL=http://localhost:4000
