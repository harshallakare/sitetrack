# Reverse proxy + automatic HTTPS (Let's Encrypt) for the web app.
#
# Set DOMAIN in .env.production to your real domain (e.g. app.example.com)
# and point its DNS A/AAAA record at this server before deploying -- Caddy
# requests and renews the certificate itself, no certbot/nginx config needed.
#
# Left as `localhost` this just serves plain HTTP, useful for a first smoke
# test on a server without DNS set up yet.

{$DOMAIN:localhost} {
	# Gateway webhooks (Razorpay, etc.) go straight to the api process (both
	# api and web run in the single `app` container -- see Dockerfile),
	# bypassing the Next.js proxy -- there's no logged-in session to proxy
	# through, and the route authenticates itself via signature, not cookies.
	# Paste https://<your-domain>/webhooks/razorpay into the Razorpay dashboard.
	handle /webhooks/* {
		reverse_proxy app:4000
	}

	handle {
		reverse_proxy app:3000
	}

	encode gzip

	header {
		X-Content-Type-Options nosniff
		Referrer-Policy strict-origin-when-cross-origin
	}
}
