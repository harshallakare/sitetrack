{
  "name": "sitetrack",
  "private": true,
  "version": "0.1.0",
  "engines": {
    "node": ">=20.0.0"
  },
  "packageManager": "pnpm@9.15.0",
  "scripts": {
    "build": "turbo run build",
    "dev": "turbo run dev",
    "lint": "turbo run lint",
    "test": "turbo run test",
    "db:generate": "pnpm --filter @sitetrack/database db:generate",
    "db:migrate:dev": "pnpm --filter @sitetrack/database db:migrate:dev",
    "db:migrate:deploy": "pnpm --filter @sitetrack/database db:migrate:deploy",
    "db:seed": "pnpm --filter @sitetrack/database db:seed",
    "db:studio": "pnpm --filter @sitetrack/database db:studio"
  },
  "devDependencies": {
    "turbo": "^2.3.0",
    "typescript": "^5.6.0"
  }
}
