# Dependencies & build output
node_modules/
.turbo/
dist/
.next/
out/
*.tsbuildinfo
coverage/

# Secrets -- NEVER commit. `.env*` (no slash) matches at every depth, covering
# apps/api/.env, packages/database/.env, and .env.production on the server.
# Templates live in .env.example / .env.production.example (explicitly un-ignored).
.env*
!.env.example
!.env.production.example

# Local database & generated schema (schema.prisma is rendered from
# schema.template.prisma by generate-schema.js; the template is the source)
packages/database/prisma/schema.prisma
packages/database/prisma/dev.db
packages/database/prisma/dev.db-journal
*.db

# prisma/migrations is generated per-run by generate-schema.js, copied from
# whichever prisma/engines/<provider>/migrations matches DATABASE_PROVIDER.
# Those per-engine folders are the real, tracked migration history.
packages/database/prisma/migrations/

# User-uploaded files (local disk storage)
apps/api/uploads/

# Database backup/restore snapshots -- may contain real customer data, never versioned
apps/api/backups/

# OS / editor / logs
.DS_Store
npm-debug.log*
pnpm-debug.log*

# Reference material (SiteWise screenshots doc) + Word lock files --
# remove these two lines if you want the doc versioned
*.docx
~$*
